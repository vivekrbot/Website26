# Cloudinary image upload — CMS case study editor (dev only)
# Copy this file to .env.development.local and fill in your values.
# IMPORTANT: Use .env.development.local — Vite excludes it from production builds.
#
# In Cloudinary: Settings → Upload → Upload presets → Add preset
#   • Signing Mode = Unsigned
#   • Allowed HTTP origins = http://localhost:5173

VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset
